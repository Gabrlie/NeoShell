{
  "expo": {
    "name": "NeoShell",
    "slug": "neoshell",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "neoshell",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/34dbc163-b515-4f2f-94f8-c5ec557bd163",
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0,
      "enableBsdiffPatchSupport": true
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neoshell.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1117",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.neoshell.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-updates",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "允许 NeoShell 使用面容识别来解锁应用和验证敏感操作。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34dbc163-b515-4f2f-94f8-c5ec557bd163"
      }
    },
    "owner": "gabrlie"
  }
}
